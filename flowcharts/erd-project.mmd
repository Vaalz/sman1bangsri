erDiagram
  USERS {
    BIGINT id PK
    VARCHAR name
    VARCHAR username
    VARCHAR email
    VARCHAR password
    ENUM role
    BOOLEAN is_active
    TIMESTAMP email_verified_at
    TIMESTAMP created_at
    TIMESTAMP updated_at
  }

  PERSONAL_ACCESS_TOKENS {
    BIGINT id PK
    VARCHAR tokenable_type
    BIGINT tokenable_id
    TEXT name
    VARCHAR token
    TEXT abilities
    TIMESTAMP last_used_at
    TIMESTAMP expires_at
    TIMESTAMP created_at
    TIMESTAMP updated_at
  }

  PASSWORD_RESET_TOKENS {
    VARCHAR email PK
    VARCHAR token
    TIMESTAMP created_at
  }

  SESSIONS {
    VARCHAR id PK
    BIGINT user_id
    VARCHAR ip_address
    TEXT user_agent
    LONGTEXT payload
    INT last_activity
  }

  ACTIVITY_LOGS {
    BIGINT id PK
    BIGINT user_id FK
    VARCHAR action
    VARCHAR resource
    TEXT description
    VARCHAR ip_address
    TIMESTAMP created_at
    TIMESTAMP updated_at
  }

  BERITA {
    BIGINT id PK
    VARCHAR judul
    VARCHAR slug
    VARCHAR kategori
