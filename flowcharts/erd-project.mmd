    TEXT konten
    VARCHAR foto
    DATE tanggal
    TIMESTAMP created_at
    TIMESTAMP updated_at
  }

  GALERI {
    BIGINT id PK
    VARCHAR judul
    VARCHAR kategori
    VARCHAR foto
